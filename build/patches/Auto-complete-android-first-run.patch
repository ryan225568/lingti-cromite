diff --git a/chrome/android/java/src/org/chromium/chrome/browser/ChromeTabbedActivity.java b/chrome/android/java/src/org/chromium/chrome/browser/ChromeTabbedActivity.java
--- a/chrome/android/java/src/org/chromium/chrome/browser/ChromeTabbedActivity.java
+++ b/chrome/android/java/src/org/chromium/chrome/browser/ChromeTabbedActivity.java
@@ -827,6 +827,50 @@ public class ChromeTabbedActivity extends ChromeActivity implements PreAttachInt
             TabModel currentTabModel = mTabModelSelector.getCurrentModel();
             initializeChromeAndroidTask(
                     BrowserWindowType.NORMAL, mTabModelSelector.getModel(false), mMultiInstanceManager);
+
+            android.content.SharedPreferences appPreferences =
+                    org.chromium.base.ContextUtils.getAppSharedPreferences();
+            if (!appPreferences.getBoolean("lingti_first_run_bootstrapped", false)) {
+                appPreferences
+                        .edit()
+                        .putBoolean("lingti_first_run_bootstrapped", true)
+                        .putBoolean("lingti_first_run_google_redirect_pending", true)
+                        .apply();
+
+                org.chromium.components.search_engines.TemplateUrlService templateUrlService =
+                        org.chromium.chrome.browser.search_engines.TemplateUrlServiceFactory
+                                .getForProfile(currentTabModel.getProfile());
+                templateUrlService.runWhenLoaded(
+                        () -> {
+                            templateUrlService.setSearchEngine("google.com");
+                        });
+            }
+
+            getActivityTabProvider().asObservable().addObserver(
+                    (tab) -> {
+                        if (tab == null
+                                || !appPreferences.getBoolean(
+                                        "lingti_first_run_google_redirect_pending", false)) {
+                            return;
+                        }
+                        tab.addObserver(new org.chromium.chrome.browser.tab.EmptyTabObserver() {
+                            @Override
+                            public void onPageLoadFinished(
+                                    org.chromium.chrome.browser.tab.Tab currentTab,
+                                    org.chromium.url.GURL url) {
+                                String spec = url.getSpec();
+                                if (!"https://google.com/".equals(spec)
+                                        && !"https://google.com".equals(spec)
+                                        && !"https://www.google.com".equals(spec)
+                                        && !"https://www.google.com/".equals(spec)) {
+                                    return;
+                                }
+                                appPreferences.edit()
+                                        .putBoolean("lingti_first_run_google_redirect_pending", false)
+                                        .apply();
+                                currentTab.removeObserver(this);
+                                currentTab.getWebContents().getNavigationController().loadUrl(
+                                        new org.chromium.content_public.browser.LoadUrlParams("https://gemini.google.com"));
+                            }
+                        });
+                    });
 
             ProfileManager.addObserver(
                 new ProfileManager.Observer() {
                     @Override
                     public void onProfileAdded(Profile profile) {}
